# ============================================================================
# AumOS Physical AI — Environment Variables
# All variables use the AUMOS_PHYSICAL_AI_ prefix (except core AumOS vars)
# ============================================================================

# ---------------------------------------------------------------------------
# Core AumOS settings (inherited from aumos-common)
# ---------------------------------------------------------------------------
AUMOS_ENVIRONMENT=development
AUMOS_LOG_LEVEL=INFO

# Database (Postgres via asyncpg)
AUMOS_DATABASE_URL=postgresql+asyncpg://aumos:aumos_dev@localhost:5432/aumos_physical_ai

# Kafka
AUMOS_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
AUMOS_KAFKA_CONSUMER_GROUP=aumos-physical-ai

# Redis
AUMOS_REDIS_URL=redis://localhost:6379/0

# JWT
AUMOS_JWT_SECRET=change-me-in-production
AUMOS_JWT_ALGORITHM=HS256
AUMOS_JWT_EXPIRE_MINUTES=60

# ---------------------------------------------------------------------------
# Physical AI — Service-specific settings
# ---------------------------------------------------------------------------

# BlenderProc rendering service
AUMOS_PHYSICAL_AI_BLENDERPROC_URL=http://localhost:9090
AUMOS_PHYSICAL_AI_BLENDERPROC_TIMEOUT_SECONDS=300

# Sensor simulation service
AUMOS_PHYSICAL_AI_SENSOR_SIMULATOR_URL=http://localhost:9091
AUMOS_PHYSICAL_AI_LIDAR_POINT_CLOUD_MAX_POINTS=100000
AUMOS_PHYSICAL_AI_CAMERA_RESOLUTION_WIDTH=1920
AUMOS_PHYSICAL_AI_CAMERA_RESOLUTION_HEIGHT=1080
AUMOS_PHYSICAL_AI_IMU_SAMPLE_RATE_HZ=200

# Sim-to-real transfer
AUMOS_PHYSICAL_AI_SIM2REAL_MODEL_REGISTRY_URL=http://localhost:8080
AUMOS_PHYSICAL_AI_DOMAIN_GAP_THRESHOLD=0.15
AUMOS_PHYSICAL_AI_ADAPTATION_EPOCHS_DEFAULT=50

# Domain randomization
AUMOS_PHYSICAL_AI_RANDOMIZATION_SEED=42
AUMOS_PHYSICAL_AI_MAX_RANDOMIZATION_VARIATIONS=1000

# Sensor fusion output
AUMOS_PHYSICAL_AI_FUSION_OUTPUT_BUCKET=aumos-physical-ai
AUMOS_PHYSICAL_AI_FUSION_OUTPUT_FORMAT=rosbag2

# Object storage (MinIO / S3)
AUMOS_PHYSICAL_AI_MINIO_ENDPOINT=http://localhost:9000
AUMOS_PHYSICAL_AI_MINIO_ACCESS_KEY=minioadmin
AUMOS_PHYSICAL_AI_MINIO_SECRET_KEY=minioadmin
